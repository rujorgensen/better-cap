{
    "name": "bettercap",
    "type": "module",
    "version": "0.0.2",
    "scripts": {
        "//-01a": "// ****************************************************************************",
        "//-01b": "// *** Docker                                                                ",
        "//-01c": "// ****************************************************************************",
        "docker:bettercap:dev:up": "docker compose -p bettercap -f .deploy/docker-compose.dev.yml up -d --build",
        "docker:bettercap:dev:down": "docker compose -p bettercap -f .deploy/docker-compose.dev.yml down",
        "//-02a": "// ****************************************************************************",
        "//-02b": "// *** Prisma                                                                  ",
        "//-02c": "// ****************************************************************************",
        "prisma:generate:bettercap": "bunx --bun prisma generate --config prisma/prisma.config.ts --generator=client",
        "prisma:migrate:dev:bettercap": "bunx --bun prisma migrate dev --config prisma/prisma.config.ts --name=initial",
        "//-03a": "// ****************************************************************************",
        "//-03b": "// *** Better Auth                                                             ",
        "//-03c": "// ****************************************************************************",
        "auth:generate": "bunx --bun @better-auth/cli@latest generate --config=./apps/backend/src/auth.ts",
        "//-04a": "// ****************************************************************************",
        "//-04b": "// *** Misc                                                                    ",
        "//-04c": "// ****************************************************************************",
        "prisma:deploy": "(bun prisma:generate:bettercap || true) && (bun prisma:migrate:dev:bettercap || true)"
    },
    "dependencies": {
        "@angular-devkit/build-angular": "21.2.3",
        "@angular/common": "21.2.5",
        "@angular/compiler": "21.2.5",
        "@angular/core": "21.2.5",
        "@angular/forms": "21.2.5",
        "@angular/platform-browser": "21.2.5",
        "@angular/platform-server": "21.2.5",
        "@angular/router": "21.2.5",
        "@angular/service-worker": "21.2.5",
        "@better-auth/cli": "^1.4.21",
        "@better-auth/prisma-adapter": "1.5.6",
        "@capacitor/android": "8.2.0",
        "@capacitor/app": "8.0.1",
        "@capacitor/assets": "3.0.5",
        "@capacitor/browser": "8.0.2",
        "@capacitor/core": "8.2.0",
        "@capacitor/network": "8.0.1",
        "@capacitor/preferences": "8.0.1",
        "@elysiajs/cors": "1.4.1",
        "@elysiajs/static": "1.4.7",
        "@prisma/adapter-pg": "7.5.0",
        "@prisma/client": "7.5.0",
        "better-auth": "1.5.6",
        "better-auth-capacitor": "0.3.6",
        "elysia": "1.4.28",
        "ngx-sonner": "3.1.0",
        "rxjs": "7.8.2"
    },
    "devDependencies": {
        "@analogjs/vite-plugin-angular": "2.3.1",
        "@angular-devkit/core": "21.2.3",
        "@angular-devkit/schematics": "21.2.3",
        "@angular/build": "21.2.3",
        "@angular/cli": "21.2.3",
        "@angular/compiler-cli": "21.2.5",
        "@angular/language-service": "21.2.5",
        "@capacitor/cli": "8.2.0",
        "@nx/angular": "22.6.1",
        "@nx/devkit": "22.6.1",
        "@nx/js": "22.6.1",
        "@nx/vite": "22.6.1",
        "@nx/web": "22.6.1",
        "@schematics/angular": "21.2.3",
        "@swc-node/register": "1.11.1",
        "@swc/core": "1.15.21",
        "@swc/helpers": "0.5.19",
        "@types/bun": "1.3.11",
        "@types/node": "25.5.0",
        "jsdom": "28.1.0",
        "nx": "22.6.1",
        "prisma": "7.5.0",
        "tslib": "2.8.1",
        "typescript": "5.9.3",
        "vite": "7.3.1",
        "vite-plugin-dts": "4.5.4",
        "vite-tsconfig-paths": "6.1.1"
    },
    "packageManager": "bun@1.3.11"
}